    {
      "id": "Zpz8WC79gyEVa5M2voH-U",
      "type": "text",
      "x": 433.77734375,
      "y": 897.2392578125,
      "width": 663.8233032226562,
      "height": 140,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Q",
      "roundness": null,
      "seed": 2042344551,
      "version": 643,
      "versionNonce": 1050762631,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775829515647,
      "link": null,
      "locked": false,
      "text": "COA tree remains in place across activities i think - similar to obsidian.\nClicking an item in the coa tree always brings you back to that ledger.\nIf I have a report, clicking an account in that report takes you back to that ledger.\nTabs can be linked to follow each other using selected data (like dates, etc).\nIs scheduled transactions a global tool? -> it affects all accounts...???\nIs budgeting a global tool?? Or should it be in the activity bar???\nWhat would be considered a global tool suitable for the bottom panel??",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "COA tree remains in place across activities i think - similar to obsidian.\nClicking an item in the coa tree always brings you back to that ledger.\nIf I have a report, clicking an account in that report takes you back to that ledger.\nTabs can be linked to follow each other using selected data (like dates, etc).\nIs scheduled transactions a global tool? -> it affects all accounts...???\nIs budgeting a global tool?? Or should it be in the activity bar???\nWhat would be considered a global tool suitable for the bottom panel??",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "dec_header",
      "x": 433,
      "y": 1060,
      "width": 664,
      "height": 25,
      "strokeColor": "#4a9eed",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
