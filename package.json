{
  "name": "tally",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "@tally-core/domain": "workspace:*",
    "@tally-core/logging": "workspace:*",
    "@tally-core/workspace": "workspace:*",
    "@tally-portal/ui": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  },
  "workspaces": [
    "tally-core/apps/*",
    "tally-core/packages/*",
    "tally-portal/apps/*",
    "tally-portal/packages/*",
    "tally-go/apps/*",
    "tally-cli",
    "tally-desktop"
  ],
  "scripts": {
    "ci:verify": "pnpm typecheck && pnpm test && pnpm coverage && pnpm security:secrets",
    "coverage": "vitest run --coverage",
    "dev:api": "pnpm --filter @tally-core/api dev",
    "dev:mobile": "pnpm --filter @tally-go/mobile dev",
    "dev:web": "pnpm --filter @tally-portal/web dev",
    "metrics:baseline": "pnpm --filter @tally-core/api exec tsx ../../../scripts/metrics-baseline.ts",
    "security:check": "pnpm security:secrets",
    "security:secrets": "node ./scripts/check-secrets.mjs",
    "test": "vitest run",
    "test:web:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck"
  }
}
